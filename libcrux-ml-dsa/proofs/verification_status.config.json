{
  "crate_name": "ML-DSA",
  "src_dir": "src",
  "makefile": "proofs/fstar/extraction/Makefile",
  "extraction_dir": "proofs/fstar/extraction",
  "output": "proofs/verification_status.md",
  "admit_module_prefix": "Libcrux_ml_dsa.",
  "spec_patterns": [
    "Hacspec_ml_dsa\\.",
    "Spec\\.MLDSA\\.",
    "Spec\\.Utils\\.v_G", "Spec\\.Utils\\.v_H", "Spec\\.Utils\\.v_PRF",
    "to_spec_poly_t", "to_spec_vector_t", "to_spec_matrix_t",
    "Traits\\.Specs?\\.\\w+_post"
  ],
  "range_patterns": [
    "is_i16b", "is_i32b", "is_intb",
    "is_bounded_poly", "is_bounded_vector",
    "\\bbounded\\b"
  ],
  "modules": [
    {"category": "Generic", "display": "constants", "paths": ["constants"]},
    {"category": "Generic", "display": "types", "paths": ["types"]},
    {"category": "Generic", "display": "utils", "paths": ["utils"]},
    {"category": "Generic", "display": "helper", "paths": ["helper"]},
    {"category": "Generic", "display": "lib", "paths": ["lib"]},
    {"category": "Generic", "display": "specs", "paths": ["specs"]},
    {"category": "Generic", "display": "polynomial", "paths": ["polynomial"]},
    {"category": "Generic", "display": "ntt", "paths": ["ntt"]},
    {"category": "Generic", "display": "arithmetic", "paths": ["arithmetic"]},
    {"category": "Generic", "display": "matrix", "paths": ["matrix"]},
    {"category": "Generic", "display": "sample", "paths": ["sample"]},
    {"category": "Generic", "display": "samplex4", "paths": ["samplex4"]},
    {"category": "Generic", "display": "pre_hash", "paths": ["pre_hash"]},
    {"category": "Generic", "display": "hash_functions", "paths": ["hash_functions"]},
    {"category": "Generic", "display": "encoding",
     "paths": ["encoding", "encoding/commitment", "encoding/error", "encoding/gamma1",
               "encoding/signature", "encoding/signing_key", "encoding/t0", "encoding/t1",
               "encoding/verification_key"]},
    {"category": "Generic", "display": "ml_dsa_generic",
     "paths": ["ml_dsa_generic", "ml_dsa_generic/instantiations",
               "ml_dsa_generic/instantiations/avx2", "ml_dsa_generic/multiplexing"]},
    {"category": "Generic", "display": "ml_dsa_*",
     "paths": ["ml_dsa_44", "ml_dsa_65", "ml_dsa_87"]},
    {"category": "Generic", "display": "simd (top)", "paths": ["simd"]},
    {"category": "Generic", "display": "simd/traits",
     "paths": ["simd/traits", "simd/traits/specs"]},
    {"category": "Generic", "display": "simd/tests", "paths": ["simd/tests"]},
    {"category": "Portable", "display": "vector_type", "paths": ["simd/portable/vector_type"]},
    {"category": "Portable", "display": "arithmetic", "paths": ["simd/portable/arithmetic"]},
    {"category": "Portable", "display": "ntt", "paths": ["simd/portable/ntt"]},
    {"category": "Portable", "display": "invntt", "paths": ["simd/portable/invntt"]},
    {"category": "Portable", "display": "sample", "paths": ["simd/portable/sample"]},
    {"category": "Portable", "display": "encoding",
     "paths": ["simd/portable/encoding", "simd/portable/encoding/commitment",
               "simd/portable/encoding/error", "simd/portable/encoding/gamma1",
               "simd/portable/encoding/t0", "simd/portable/encoding/t1"]},
    {"category": "Portable", "display": "simd (top)", "paths": ["simd/portable"]},
    {"category": "Avx2", "display": "vector_type", "paths": ["simd/avx2/vector_type"]},
    {"category": "Avx2", "display": "arithmetic", "paths": ["simd/avx2/arithmetic"]},
    {"category": "Avx2", "display": "ntt", "paths": ["simd/avx2/ntt"]},
    {"category": "Avx2", "display": "invntt", "paths": ["simd/avx2/invntt"]},
    {"category": "Avx2", "display": "rejection_sample",
     "paths": ["simd/avx2/rejection_sample", "simd/avx2/rejection_sample/less_than_eta",
               "simd/avx2/rejection_sample/less_than_field_modulus",
               "simd/avx2/rejection_sample/shuffle_table"]},
    {"category": "Avx2", "display": "encoding",
     "paths": ["simd/avx2/encoding", "simd/avx2/encoding/commitment",
               "simd/avx2/encoding/error", "simd/avx2/encoding/gamma1",
               "simd/avx2/encoding/t0", "simd/avx2/encoding/t1"]},
    {"category": "Avx2", "display": "simd (top)", "paths": ["simd/avx2"]}
  ]
}
