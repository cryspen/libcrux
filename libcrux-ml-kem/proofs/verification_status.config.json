    "Hacspec_ml_kem\\.",
    "Spec\\.Utils\\.v_G",
    "Spec\\.Utils\\.v_H",
    "Spec\\.Utils\\.v_PRF",
    "to_spec_poly_t",
    "to_spec_vector_t",
    "to_spec_matrix_t",
    "Traits\\.Spec\\.\\w+_post"
  ],
  "range_patterns": [
    "is_i16b",
    "is_bounded_poly",
    "is_bounded_vector",
    "\\bbounded\\b",
    "is_intb",
    "is_i32b"
  ],
  "modules": [
    {"category": "Generic", "display": "constants", "paths": ["constants"]},
    {"category": "Generic", "display": "constant_time_ops", "paths": ["constant_time_ops"]},
