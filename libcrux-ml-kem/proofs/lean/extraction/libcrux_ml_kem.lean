def compare_ciphertexts_select_shared_secret_in_constant_time
    (lhs_c : (RustSlice u8))
    (rhs_c : (RustSlice u8))
    (lhs_s : (RustSlice u8))
    (rhs_s : (RustSlice u8)) :
    RustM (RustArray u8 32) := do
  let selector : u8 ← (compare_ciphertexts_in_constant_time lhs_c rhs_c);
