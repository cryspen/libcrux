namespace libcrux_ml_kem.hash_functions

--  The SHA3 block size.
def BLOCK_SIZE : usize := (168 : usize)

--  The size of 3 SHA3 blocks.
def THREE_BLOCKS : usize :=
  RustM.of_isOk (do (BLOCK_SIZE *? (3 : usize))) (by rfl)

--  Abstraction for the hashing, to pick the fastest version depending on the
--  platform features available.
-- 
--  There are 3 instantiations of this trait right now, using the libcrux-sha3 crate.
--  - AVX2
--  - NEON
--  - Portable
class Hash.AssociatedTypes (Self : Type) (K : usize) where

class Hash (Self : Type) (K : usize)
  [associatedTypes : outParam (Hash.AssociatedTypes (Self : Type) (K : usize))]
  where
  G (Self) (K) : ((RustSlice u8) -> RustM (RustArray u8 64))
  H (Self) (K) : ((RustSlice u8) -> RustM (RustArray u8 32))
  PRF (Self) (K) (LEN : usize) : ((RustSlice u8) -> RustM (RustArray u8 LEN))
  PRFxN (Self) (K) (LEN : usize) :
    ((RustArray (RustArray u8 33) K) -> RustM (RustArray (RustArray u8 LEN) K))
  shake128_init_absorb_final (Self) (K) :
    ((RustArray (RustArray u8 34) K) -> RustM Self)
  shake128_squeeze_first_three_blocks (Self) (K) :
    (Self ->
    RustM (rust_primitives.hax.Tuple2 Self (RustArray (RustArray u8 504) K)))
  shake128_squeeze_next_block (Self) (K) :
    (Self ->
    RustM (rust_primitives.hax.Tuple2 Self (RustArray (RustArray u8 168) K)))

end libcrux_ml_kem.hash_functions


