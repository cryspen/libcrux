        *? VECTOR_U_COMPRESSION_FACTOR))
      /? (8 : usize)))
    (by rfl)

def C1_SIZE : usize := RustM.of_isOk (do (C1_BLOCK_SIZE *? RANK)) (by rfl)

def VECTOR_V_COMPRESSION_FACTOR : usize := (4 : usize)

def C2_SIZE : usize :=
  RustM.of_isOk
    (do
    ((← (libcrux_ml_kem.constants.COEFFICIENTS_IN_RING_ELEMENT
        *? VECTOR_V_COMPRESSION_FACTOR))
      /? (8 : usize)))
    (by rfl)

