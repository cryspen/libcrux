--  If `selector` is not zero, return the bytes in `rhs`; return the bytes in
--  `lhs` otherwise.
def select_ct (lhs : (RustSlice u8)) (rhs : (RustSlice u8)) (selector : u8) :
    RustM (RustArray u8 32) := do
  let mask : u8 ←
    (core_models.num.Impl_6.wrapping_sub (← (is_non_zero selector)) (1 : u8));
  let _ := rust_primitives.hax.Tuple0.mk;
  let out : (RustArray u8 32) ←
    (rust_primitives.hax.repeat (0 : u8) (32 : usize));
  let out : (RustArray u8 32) ←
    (rust_primitives.hax.folds.fold_range
      (0 : usize)
      libcrux_ml_kem.constants.SHARED_SECRET_SIZE
      (fun out i =>
        (do (hax_lib.prop.Impl.from_bool true) : RustM hax_lib.prop.Prop))
      out
      (fun out i =>
        (do
        let _ := rust_primitives.hax.Tuple0.mk;
        let outi : u8 ←
          ((← ((← lhs[i]_?) &&&? mask))
            |||? (← ((← rhs[i]_?) &&&? (← (~? mask)))));
        let _ := rust_primitives.hax.Tuple0.mk;
        let out : (RustArray u8 32) ←
          (rust_primitives.hax.monomorphized_update_at.update_at_usize
            out
            i
            outi);
        (pure out) :
        RustM (RustArray u8 32))));
  let _ := rust_primitives.hax.Tuple0.mk;
  (pure out)

set_option hax_mvcgen.specset "bv" in
@[hax_spec]
def
      select_ct.spec
      (lhs : (RustSlice u8))
      (rhs : (RustSlice u8))
      (selector : u8) :
    Spec
      (requires := do
        ((← ((← (core_models.slice.Impl.len u8 lhs))
            ==? (← (core_models.slice.Impl.len u8 rhs))))
          &&? (← ((← (core_models.slice.Impl.len u8 lhs))
            ==? libcrux_ml_kem.constants.SHARED_SECRET_SIZE))))
      (ensures := fun
          result => do
          if (← (selector ==? (0 : u8))) then do
            (core_models.cmp.PartialEq.eq
              (RustArray u8 32)
              (RustSlice u8) result lhs)
          else do
            (core_models.cmp.PartialEq.eq
              (RustArray u8 32)
              (RustSlice u8) result rhs))
      (select_ct (lhs : (RustSlice u8)) (rhs : (RustSlice u8)) (selector : u8))
    := {
  pureRequires := by hax_construct_pure <;> bv_decide
  pureEnsures := by hax_construct_pure <;> bv_decide
  contract := by hax_mvcgen [select_ct] <;> bv_decide
}

def select_shared_secret_in_constant_time
    (lhs : (RustSlice u8))
    (rhs : (RustSlice u8))
    (selector : u8) :
    RustM (RustArray u8 32) := do
