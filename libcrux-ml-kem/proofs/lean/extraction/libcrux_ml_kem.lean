--  Return 1 if `value` is not zero and 0 otherwise.
def inz (value : u8) : RustM u8 := do
  let _orig_value : u8 := value;
  let value : u16 ← (rust_primitives.hax.cast_op value : RustM u16);
  let result : u8 ←
    (rust_primitives.hax.cast_op
      (← ((← (core_models.num.Impl_7.wrapping_add (← (~? value)) (1 : u16)))
        >>>? (8 : i32))) :
      RustM u8);
  let res : u8 ← (result &&&? (1 : u8));
  let _ := rust_primitives.hax.Tuple0.mk;
  (pure res)

set_option hax_mvcgen.specset "bv" in
@[hax_spec]
def inz.spec (value : u8) :
    Spec
      (requires := do pure True)
      (ensures := fun
          result => do
          if (← (value ==? (0 : u8))) then do
            (result ==? (0 : u8))
          else do
            (result ==? (1 : u8)))
      (inz (value : u8)) := {
  pureRequires := by hax_construct_pure <;> bv_decide
  pureEnsures := by hax_construct_pure <;> bv_decide
  contract := by hax_mvcgen [inz] <;> bv_decide
}

def is_non_zero (value : u8) : RustM u8 := do
  (core_models.hint.black_box u8 (← (inz value)))

