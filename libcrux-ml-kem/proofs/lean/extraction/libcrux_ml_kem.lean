def G (input : (RustSlice u8)) : RustM (RustArray u8 64) := do
  let digest : (RustArray u8 64) ←
    (rust_primitives.hax.repeat (0 : u8) (64 : usize));
  let digest : (RustArray u8 64) ← (libcrux_sha3.portable.sha512 digest input);
  (pure digest)

