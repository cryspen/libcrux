  pureEnsures := by hax_construct_pure <;> bv_decide
  contract := by hax_mvcgen [PRFxN] <;> bv_decide
}

@[spec]
def shake128_init_absorb_final (K : usize)
    (input : (RustArray (RustArray u8 34) K)) :
    RustM (PortableHash (K)) := do
  let _ ←
    if true then do
      let _ ←
        (hax_lib.assert
          (← ((← ((← (K ==? (2 : usize))) ||? (← (K ==? (3 : usize)))))
            ||? (← (K ==? (4 : usize))))));
      (pure rust_primitives.hax.Tuple0.mk)
    else do
      (pure rust_primitives.hax.Tuple0.mk);
  let shake128_state : (PortableHash (K)) :=
    (PortableHash.mk
      (shake128_state := (← (rust_primitives.hax.repeat
        (← (libcrux_sha3.portable.incremental.shake128_init
          rust_primitives.hax.Tuple0.mk))
        K))));
  let shake128_state : (PortableHash (K)) ←
    (rust_primitives.hax.folds.fold_range
      (0 : usize)
      K
      (fun shake128_state _ => (do (pure true) : RustM Bool))
      shake128_state
      (fun shake128_state i =>
        (do
        (pure {shake128_state
        with shake128_state := (←
        (rust_primitives.hax.monomorphized_update_at.update_at_usize
          (PortableHash.shake128_state shake128_state)
          i
          (← (libcrux_sha3.portable.incremental.shake128_absorb_final
            (← (PortableHash.shake128_state shake128_state)[i]_?)
            (← (rust_primitives.unsize (← input[i]_?)))))))}) :
        RustM (PortableHash (K)))));
  (pure shake128_state)

@[spec]
def shake128_squeeze_first_three_blocks (K : usize) (st : (PortableHash (K))) :
    RustM
    (rust_primitives.hax.Tuple2
      (PortableHash (K))
      (RustArray (RustArray u8 504) K))
    := do
  let _ ←
    if true then do
      let _ ←
        (hax_lib.assert
          (← ((← ((← (K ==? (2 : usize))) ||? (← (K ==? (3 : usize)))))
            ||? (← (K ==? (4 : usize))))));
      (pure rust_primitives.hax.Tuple0.mk)
    else do
      (pure rust_primitives.hax.Tuple0.mk);
  let out : (RustArray (RustArray u8 504) K) ←
    (rust_primitives.hax.repeat
      (← (rust_primitives.hax.repeat (0 : u8) (504 : usize)))
      K);
  let ⟨out, st⟩ ←
    (rust_primitives.hax.folds.fold_range
      (0 : usize)
      K
      (fun ⟨out, st⟩ _ => (do (pure true) : RustM Bool))
      (rust_primitives.hax.Tuple2.mk out st)
      (fun ⟨out, st⟩ i =>
        (do
        let ⟨tmp0, tmp1⟩ ←
          (libcrux_sha3.portable.incremental.shake128_squeeze_first_three_blocks
            (← (PortableHash.shake128_state st)[i]_?)
            (← out[i]_?));
        let st : (PortableHash (K)) :=
          {st
          with shake128_state := (←
          (rust_primitives.hax.monomorphized_update_at.update_at_usize
            (PortableHash.shake128_state st)
            i
            tmp0))};
        let out : (RustArray (RustArray u8 504) K) ←
          (rust_primitives.hax.monomorphized_update_at.update_at_usize
            out
