def PRFxN (K : usize) (LEN : usize) (input : (RustArray (RustArray u8 33) K)) :
    RustM (RustArray (RustArray u8 LEN) K) := do
  let _ ←
    if true then do
      let _ ←
        (hax_lib.assert
          (← ((← ((← (K ==? (2 : usize))) ||? (← (K ==? (3 : usize)))))
            ||? (← (K ==? (4 : usize))))));
      (pure rust_primitives.hax.Tuple0.mk)
    else do
      (pure rust_primitives.hax.Tuple0.mk);
  let out : (RustArray (RustArray u8 LEN) K) ←
    (rust_primitives.hax.repeat
      (← (rust_primitives.hax.repeat (0 : u8) LEN))
      K);
  let out : (RustArray (RustArray u8 LEN) K) ←
    (rust_primitives.hax.folds.fold_range
      (0 : usize)
      K
      (fun out _ => (do (pure true) : RustM Bool))
      out
      (fun out i =>
        (do
        (rust_primitives.hax.monomorphized_update_at.update_at_usize
          out
          i
          (← (libcrux_sha3.portable.shake256
            (← out[i]_?)
            (← (rust_primitives.unsize (← input[i]_?)))))) :
        RustM (RustArray (RustArray u8 LEN) K))));
  (pure out)

