  RustM.of_isOk
    (do
    ((← ((← (RANK *? libcrux_ml_kem.constants.COEFFICIENTS_IN_RING_ELEMENT))
        *? libcrux_ml_kem.constants.BITS_PER_COEFFICIENT))
      /? (8 : usize)))
    (by rfl)

def CPA_PKE_PUBLIC_KEY_SIZE : usize :=
  RustM.of_isOk (do (T_AS_NTT_ENCODED_SIZE +? (32 : usize))) (by rfl)

def CPA_PKE_CIPHERTEXT_SIZE : usize :=
