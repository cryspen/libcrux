--  Return 1 if the bytes of `lhs` and `rhs` do not exactly
--  match and 0 otherwise.
def compare (lhs : (RustSlice u8)) (rhs : (RustSlice u8)) : RustM u8 := do
  let r : u8 := (0 : u8);
  let r : u8 ←
    (rust_primitives.hax.folds.fold_range
      (0 : usize)
      (← (core_models.slice.Impl.len u8 lhs))
      (fun r i =>
        (do (hax_lib.prop.Impl.from_bool true) : RustM hax_lib.prop.Prop))
      r
      (fun r i =>
        (do
        let nr : u8 ← (r |||? (← ((← lhs[i]_?) ^^^? (← rhs[i]_?))));
        let _ := rust_primitives.hax.Tuple0.mk;
        let r : u8 := nr;
        (pure r) :
        RustM u8)));
  (is_non_zero r)

set_option hax_mvcgen.specset "bv" in
@[hax_spec]
def compare.spec (lhs : (RustSlice u8)) (rhs : (RustSlice u8)) :
    Spec
      (requires := do
        ((← (core_models.slice.Impl.len u8 lhs))
          ==? (← (core_models.slice.Impl.len u8 rhs))))
      (ensures := fun
          result => do
          if
          (← (core_models.cmp.PartialEq.eq
            (RustSlice u8)
            (RustSlice u8) lhs rhs)) then do
            (result ==? (0 : u8))
          else do
            (result ==? (1 : u8)))
      (compare (lhs : (RustSlice u8)) (rhs : (RustSlice u8))) := {
  pureRequires := by hax_construct_pure <;> bv_decide
  pureEnsures := by hax_construct_pure <;> bv_decide
  contract := by hax_mvcgen [compare] <;> bv_decide
}

