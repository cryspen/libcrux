namespace libcrux_ml_kem.constants

--  Each field element needs floor(log_2(FIELD_MODULUS)) + 1 = 12 bits to represent
def BITS_PER_COEFFICIENT : usize := (12 : usize)

--  Coefficients per ring element
def COEFFICIENTS_IN_RING_ELEMENT : usize := (256 : usize)

--  Bits required per (uncompressed) ring element
def BITS_PER_RING_ELEMENT : usize :=
  RustM.of_isOk (do (COEFFICIENTS_IN_RING_ELEMENT *? (12 : usize))) (by rfl)

--  Bytes required per (uncompressed) ring element
def BYTES_PER_RING_ELEMENT : usize :=
  RustM.of_isOk (do (BITS_PER_RING_ELEMENT /? (8 : usize))) (by rfl)

--  The size of an ML-KEM shared secret.
def SHARED_SECRET_SIZE : usize := (32 : usize)

def CPA_PKE_KEY_GENERATION_SEED_SIZE : usize := (32 : usize)

--  SHA3 256 digest size
def H_DIGEST_SIZE : usize := (32 : usize)

--  SHA3 512 digest size
def G_DIGEST_SIZE : usize := (64 : usize)

--  K * BITS_PER_RING_ELEMENT / 8
-- 
--  [eurydice] Note that we can\'t use const generics here because that breaks
--             C extraction with eurydice.
def ranked_bytes_per_ring_element (rank : usize) : RustM usize := do
  ((← (rank *? BITS_PER_RING_ELEMENT)) /? (8 : usize))

set_option hax_mvcgen.specset "bv" in
@[hax_spec]
def ranked_bytes_per_ring_element.spec (rank : usize) :
    Spec
      (requires := do (rank <=? (4 : usize)))
      (ensures := fun
          result => do
          (result ==? (← ((← (rank *? BITS_PER_RING_ELEMENT)) /? (8 : usize)))))
      (ranked_bytes_per_ring_element (rank : usize)) := {
  pureRequires := by hax_construct_pure <;> bv_decide
  pureEnsures := by hax_construct_pure <;> bv_decide
  contract := by hax_mvcgen [ranked_bytes_per_ring_element] <;> bv_decide
}

end libcrux_ml_kem.constants


